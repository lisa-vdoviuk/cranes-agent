+
+BLOCKED_DOMAINS = {
+    "facebook.com",
+    "instagram.com",
+    "linkedin.com",
+    "xing.com",
+    "youtube.com",
+    "youtu.be",
+}
+
+IMAGE_RELEVANCE_TERMS = [
+    "kran",
+    "crane",
+    "mobilkran",
+    "autokran",
+    "mobile-crane",
+    "mobile_crane",
+    "crawler",
+    "teleskop",
+    "liebherr",
+    "tadano",
+    "demag",
+    "grove",
+    "faun",
+    "fleet",
+    "fuhrpark",
+    "vermietung",
+]
+
+COLOR_PALETTE = {
+    "black": (0, 0, 0),
+    "white": (255, 255, 255),
+    "gray": (128, 128, 128),
+    "red": (220, 20, 30),
+    "orange": (245, 130, 30),
+    "yellow": (245, 210, 30),
+    "green": (40, 150, 70),
+    "blue": (40, 90, 200),
+    "navy": (20, 35, 100),
+    "purple": (140, 60, 160),
+    "brown": (120, 80, 40),
+}

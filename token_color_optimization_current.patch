+CAPACITY_PATTERN = re.compile(
+    r"(?:\b\d{1,4}(?:[.,]\d+)?\s*(?:-|–|—|bis|to)\s*\d{1,4}(?:[.,]\d+)?\s*(?:t|to\.?|tons?|tonnes?|tonnen)\b)"
+    r"|(?:\b(?:up to|bis zu|max\.?|maximum|tragkraft|lifting capacity|capacity)\s*\d{1,4}(?:[.,]\d+)?\s*(?:t|to\.?|tons?|tonnes?|tonnen)\b)"

MAX_SEARCH_RESULTS=5
MAX_PAGES_TO_SCRAPE=3
REQUEST_TIMEOUT_SECONDS=15

# Official website filtering / clean CRM links
# When true, company_website_url is left empty unless the pipeline verifies an official company-owned site.
OFFICIAL_SITE_REQUIRED=true
# Minimum score 0-100 for accepting a website as official. Raise to 70 for stricter filtering.
SITE_MIN_OFFICIAL_SCORE=60
# Keep company profile/marketplace URLs in evidence_urls? Recommended false for clean CRM output.
ALLOW_PROFILE_AS_VERIFIED_URL=false
MAX_PROFILE_EVIDENCE_URLS=2
